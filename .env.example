# ============================================================
# Copia este archivo como .env.local y rellena los valores.
# Se obtienen en Supabase: tu proyecto → Settings → API
# ============================================================

# URL del proyecto (Project URL)
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"

# Clave pública "anon" (Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY="TU_CLAVE_ANON"

# Nombre por defecto de la asociación (opcional; también se cambia en Ajustes)
NEXT_PUBLIC_NOMBRE_ASOCIACION="Asociación Mezquita Bilal"
